# All values must be specified - default values are not interpolated anywhare.

# [REQUIRED] Location of all volumes.
VOLUMES_LOCATION=
# [REQUIRED] Location of backup volume.
DB_BACKUP_VOL="${VOLUMES_LOCATION:?}/vol_mariadb_backups"

# [REQUIRED] Mariadb "zabbix" user password.
MARIADB_PASSWORD=
# [REQUIRED] Mariadb "root" user password.
MARIADB_ROOT_PASSWORD=
# [127.0.0.1:3306] Port where MariaDb will be avialiable on host's intefaces.
MARIADB_PORT=127.0.0.1:3306

# [0.0.0.0:10051] Port where Zabbix Server will be avialiable on host's intefaces.
ZABBIX_SERVER_PORT=0.0.0.0:10051

# [127.0.0.1:8091] Port where Zabbix Frontend will be avialiable on host's intefaces.
ZABBIX_WEB_PORT=127.0.0.1:8091

# [127.0.0.1:8092] Port where PhpMyAdmin will be avialiable on host's intefaces.
PHPMYADMIN_PORT=127.0.0.1:8092

# [0.0.0.0:8099] Port where Trafik http entrypoint will be avialiable on host's intefaces.
TRAEFIK_HTTP_PORT=0.0.0.0:8099
# [0.0.0.0:8090] Port where Traefik https will be avialiable on host's intefaces.
TRAEFIK_HTTPS_PORT=0.0.0.0:8090
# [0.0.0.0:8093] Port where Traefik insecure dashboard will be avialiable on host's intefaces.
TRAEFIK_DASHBOARD_PORT=127.0.0.1:8093

# [REQUIRED] PSK identity for zabbix-aggent monitoring zabbix server.
ZABBIX_AGENT_PSK_IDENTITY=
# [REQUIRED] PSK identity for zabbix-aggent monitoring zabbix server.
ZABBIX_AGENT_PSK=
